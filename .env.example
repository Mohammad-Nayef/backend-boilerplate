ENVIRONMENT = development
DEBUG = true
ALLOWED_ORIGINS = http://localhost:5173,http://localhost:3000

# Database Configuration
DB_USER = postgres
DB_PASSWORD = postgres
DB_HOST = localhost
DB_PORT = 5432
DB_NAME = boilerplate_db
ISOLATION_LEVEL = READ COMMITTED
DB_POOL_SIZE = 4

# JWT
JWT_SECRET_KEY = change_this_to_a_secure_random_string
JWT_ALGORITHM = HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS = 60

# Auth Flow
AUTH_CODE_EXPIRE_MINUTES = 15
PASSWORD_RESET_SESSION_EXPIRE_MINUTES = 10

# Email Settings (Optional)
EMAIL_FROM_ADDRESS = no-reply@boilerplate.local
SMTP_HOST =
SMTP_PORT = 587
SMTP_USERNAME =
SMTP_PASSWORD =
SMTP_USE_TLS = true
